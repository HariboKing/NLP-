def hash_password(password: str) -> str:
    salt = secrets.token_hex(16)
    digest = hashlib.pbkdf2_hmac(
        "sha256",
        password.encode("utf-8"),
        salt.encode("utf-8"),
        120_000,
    )
    return f"{salt}${digest.hex()}"


def verify_password(password: str, password_hash: str) -> bool:
    salt, known_digest = password_hash.split("$", 1)
    computed = hashlib.pbkdf2_hmac(
        "sha256",
        password.encode("utf-8"),
        salt.encode("utf-8"),
        120_000,
    ).hex()
    return hmac.compare_digest(computed, known_digest)


def create_session(connection: sqlite3.Connection, user_id: int) -> tuple[str, str]:
    token = secrets.token_urlsafe(32)
    csrf_token = secrets.token_urlsafe(24)
    expires_at = (utc_now() + timedelta(hours=SESSION_HOURS)).isoformat(timespec="seconds")
    connection.execute(
        "INSERT INTO sessions (token, user_id, csrf_token, expires_at) VALUES (?, ?, ?, ?)",
        (token, user_id, csrf_token, expires_at),
    )
    connection.commit()
    return token, csrf_token


def get_session(connection: sqlite3.Connection, token: str | None) -> sqlite3.Row | None:
    if not token:
        return None

    session = connection.execute(
        """
        SELECT sessions.token, sessions.user_id, sessions.csrf_token, sessions.expires_at,
               users.email, users.first_name, users.last_name, users.is_platform_admin
        FROM sessions
        JOIN users ON users.id = sessions.user_id
        WHERE sessions.token = ?
        """,
        (token,),
    ).fetchone()
    if not session:
        return None

    if datetime.fromisoformat(session["expires_at"]) <= utc_now():
        destroy_session(connection, token)
        return None

    return session


def destroy_session(connection: sqlite3.Connection, token: str | None) -> None:
    if not token:
        return
    connection.execute("DELETE FROM sessions WHERE token = ?", (token,))
    connection.commit()


def get_memberships(connection: sqlite3.Connection, user_id: int) -> list[sqlite3.Row]:
    return connection.execute(
        """
        SELECT memberships.*, organizations.name AS organization_name, organizations.slug AS organization_slug
        FROM memberships
        JOIN organizations ON organizations.id = memberships.organization_id
        WHERE memberships.user_id = ?
        ORDER BY organizations.name, memberships.role
        """,
        (user_id,),
    ).fetchall()


def effective_score(attempt: sqlite3.Row) -> float | None:
    if attempt["manual_score"] is not None:
        return float(attempt["manual_score"])
    if attempt["auto_score"] is not None:
        return float(attempt["auto_score"])
    return None


def sync_reference_curriculum(connection: sqlite3.Connection) -> None:
    created_at = utc_now_iso()
    program_row = connection.execute(
        "SELECT id FROM programs WHERE title = ?",
        (PRACTITIONER_PROGRAM["title"],),
    ).fetchone()
    if program_row:
        program_id = program_row["id"]
        connection.execute(
            """
            UPDATE programs
            SET level = ?, description = ?
            WHERE id = ?
            """,
            (
                PRACTITIONER_PROGRAM["level"],
                PRACTITIONER_PROGRAM["description"],
                program_id,
            ),
        )
    else:
        cursor = connection.execute(
            """
            INSERT INTO programs (organization_id, title, level, description, created_at)
            VALUES (?, ?, ?, ?, ?)
            """,
            (
                None,
                PRACTITIONER_PROGRAM["title"],
                PRACTITIONER_PROGRAM["level"],
                PRACTITIONER_PROGRAM["description"],
                created_at,
            ),
        )
        program_id = cursor.lastrowid

    module_ids: dict[str, int] = {}
    topic_ids: dict[tuple[str, str], int] = {}
    concept_ids: dict[tuple[str, str, str], int] = {}

    for module_index, module in enumerate(PRACTITIONER_PROGRAM["modules"], start=1):
        existing_module = connection.execute(
            "SELECT id FROM modules WHERE program_id = ? AND title = ?",
            (program_id, module["title"]),
        ).fetchone()
        if existing_module:
            module_id = existing_module["id"]
            connection.execute(
                "UPDATE modules SET summary = ?, sort_order = ? WHERE id = ?",
                (module["summary"], module_index, module_id),
            )
        else:
            cursor = connection.execute(
                "INSERT INTO modules (program_id, title, summary, sort_order) VALUES (?, ?, ?, ?)",
                (program_id, module["title"], module["summary"], module_index),
            )
            module_id = cursor.lastrowid
        module_ids[module["title"]] = module_id

        connection.execute("DELETE FROM resources WHERE module_id = ?", (module_id,))
        connection.execute("DELETE FROM topics WHERE module_id = ?", (module_id,))

        for resource in module.get("resources", []):
            connection.execute(
                """
                INSERT INTO resources (module_id, title, resource_type, content, sort_order)
                VALUES (?, ?, ?, ?, ?)
                """,
                (
                    module_id,
                    resource["title"],
                    resource["resource_type"],
                    resource["content"],
                    resource["sort_order"],
                ),
            )

        for topic_index, topic in enumerate(module["topics"], start=1):
            cursor = connection.execute(
                "INSERT INTO topics (module_id, title, summary, sort_order) VALUES (?, ?, ?, ?)",
                (module_id, topic["title"], topic["summary"], topic_index),
            )
            topic_id = cursor.lastrowid
            topic_ids[(module["title"], topic["title"])] = topic_id

            for concept_index, concept in enumerate(topic["concepts"], start=1):
                cursor = connection.execute(
                    """
                    INSERT INTO concepts (topic_id, title, summary, tags_json, sort_order)
                    VALUES (?, ?, ?, ?, ?)
                    """,
                    (
                        topic_id,
                        concept["title"],
                        concept["summary"],
                        json.dumps(concept["tags"]),
                        concept_index,
                    ),
                )
                concept_ids[(module["title"], topic["title"], concept["title"])] = cursor.lastrowid

    for exercise in SEED_EXERCISES:
        module_id = module_ids[exercise["module_title"]]
        topic_id = topic_ids.get((exercise["module_title"], exercise["topic_title"]))
        concept_id = concept_ids.get(
            (exercise["module_title"], exercise["topic_title"], exercise["concept_title"])
        )
        payload = (
            None,
            module_id,
            topic_id,
            concept_id,
            exercise["exercise_type"],
            exercise["mode_support"],
            exercise["difficulty"],
            exercise["instructions"],
            exercise["prompt"],
            json.dumps(exercise["content"]),
            json.dumps(exercise["scoring"]),
            float(exercise["max_score"]),
            1 if exercise["requires_manual_review"] else 0,
            created_at,
            exercise["title"],
        )
        existing_exercise = connection.execute(
            "SELECT id FROM exercises WHERE title = ?",
            (exercise["title"],),
        ).fetchone()
        if existing_exercise:
            connection.execute(
                """
                UPDATE exercises
                SET organization_id = ?, module_id = ?, topic_id = ?, concept_id = ?,
                    exercise_type = ?, mode_support = ?, difficulty = ?, instructions = ?,
                    prompt = ?, content_json = ?, scoring_json = ?, max_score = ?,
                    requires_manual_review = ?, status = 'published', created_at = ?
                WHERE title = ?
                """,
                payload,
            )
        else:
            connection.execute(
                """
                INSERT INTO exercises (
                    organization_id, module_id, topic_id, concept_id, title, exercise_type,
                    mode_support, difficulty, instructions, prompt, content_json, scoring_json,
                    max_score, requires_manual_review, status, created_at
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'published', ?)
                """,
                (
                    None,
                    module_id,
                    topic_id,
                    concept_id,
                    exercise["title"],
                    exercise["exercise_type"],
                    exercise["mode_support"],
                    exercise["difficulty"],
                    exercise["instructions"],
                    exercise["prompt"],
                    json.dumps(exercise["content"]),
                    json.dumps(exercise["scoring"]),
                    float(exercise["max_score"]),
                    1 if exercise["requires_manual_review"] else 0,
                    created_at,
                ),
            )

    seed_titles = [exercise["title"] for exercise in SEED_EXERCISES]
    placeholders = ", ".join("?" for _ in seed_titles)
    connection.execute(
        f"""
        UPDATE exercises
        SET status = 'archived'
        WHERE organization_id IS NULL
          AND title NOT IN ({placeholders})
        """,
        tuple(seed_titles),
    )


