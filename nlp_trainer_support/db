            )

        for target_email in assignment["target_emails"]:
            connection.execute(
                "INSERT INTO assignment_targets (assignment_id, target_user_id) VALUES (?, ?)",
                (assignment_id, user_ids[target_email]),
            )

    exercise_lookup = {
        row["title"]: dict(row)
        for row in connection.execute("SELECT * FROM exercises").fetchall()
    }

    for demo_attempt in DEMO_ATTEMPTS:
        assignment_row = connection.execute(
            "SELECT * FROM assignments WHERE title = ?",
            (demo_attempt["assignment_title"],),
        ).fetchone()
        exercise_row = exercise_lookup[demo_attempt["exercise_title"]]
        result = score_submission(
            exercise=exercise_row,
            response=demo_attempt["response"],
            mode=assignment_row["mode"],
        )
        connection.execute(
            """
            INSERT INTO attempts (
                assignment_id, exercise_id, user_id, started_at, submitted_at, status,
                auto_score, manual_score, max_score, feedback
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (
                assignment_row["id"],
                exercise_row["id"],
                user_ids[demo_attempt["student_email"]],
                created_at,
                created_at,
                "submitted" if result["requires_review"] else "scored",
                result["auto_score"],
                None,
                result["max_score"],
                result["feedback"],
            ),
        )
        attempt_id = connection.execute("SELECT last_insert_rowid() AS id").fetchone()["id"]
        connection.execute(
            "INSERT INTO responses (attempt_id, response_json) VALUES (?, ?)",
            (attempt_id, json.dumps(demo_attempt["response"])),
        )

    connection.commit()
